rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAllowedUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email));
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isObserver() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'observer';
    }

    // El admin pre-registra correos; usuarios autenticados pueden leer su propio entry
    match /allowedUsers/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Cualquier jugador permitido puede leer todos los perfiles (necesario para el leaderboard)
    // Solo el propio usuario puede escribir su documento; el admin también puede (gestión de jugadores)
    match /users/{userId} {
      allow read: if isAllowedUser();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Jornadas y partidos: solo lectura para usuarios permitidos; escritura solo admin
    match /matchdays/{matchdayId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    match /leaderboard/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    // Pronósticos: cada usuario lee los suyos; todos pueden leer cuando la jornada está cerrada/finalizada
    match /predictions/{predictionId} {
      allow read: if isAllowedUser() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        get(/databases/$(database)/documents/matchdays/$(resource.data.matchdayId)).data.status in ['closed', 'finished']
      );
      allow create, update: if isAllowedUser() &&
        !isObserver() &&
        request.resource.data.userId == request.auth.uid &&
        request.time < get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.scheduledAt - duration.seconds(600);
      allow delete: if false;
    }

    // Config (tournament flags, scoring config) — readable by all players, writable only by admin
    match /config/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    // Invite tokens — admin writes them; reads go through Cloud Function (Admin SDK bypasses rules)
    match /invites/{token} {
      allow read: if false;
      allow write: if isAdmin();
    }

    match /surpriseChallenges/{challengeId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
  }
}
