{
  "name": "quinielaexpertos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "emulators": "firebase emulators:start",
    "seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed.ts",
    "seed:r32": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-r32.ts",
    "seed:r32:prod": "dotenv -e .env.local -- tsx scripts/seed-r32.ts",
    "seed:r16": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-r16.ts",
    "seed:r16:prod": "dotenv -e .env.local -- tsx scripts/seed-r16.ts",
    "seed:qf": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-qf.ts",
    "seed:qf:prod": "dotenv -e .env.local -- tsx scripts/seed-qf.ts",
    "seed:sf": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-sf.ts",
    "seed:sf:prod": "dotenv -e .env.local -- tsx scripts/seed-sf.ts",
    "seed:final": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-final.ts",
    "seed:final:prod": "dotenv -e .env.local -- tsx scripts/seed-final.ts",
    "push-to-prod": "dotenv -e .env.local -- tsx scripts/push-to-prod.ts",
    "pull-from-prod": "dotenv -e .env.local -- tsx scripts/pull-from-prod.ts",
    "fix-timestamps": "dotenv -e .env.local -- tsx scripts/fix-timestamps.ts",
    "backfill:exact-scores": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/backfill-exact-scores.ts",
    "backfill:exact-scores:prod": "dotenv -e .env.local -- tsx scripts/backfill-exact-scores.ts"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "html2canvas": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv-cli": "^11.0.0",
    "firebase-admin": "^13.10.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "~5.7.2",
    "vite": "^6.0.0"
  }
}
